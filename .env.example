# ==============================================================================
# DATAVIZ AI CONFIGURATION ENVIRONMENT TEMPLATE
# Copy this file to a file named '.env' inside the 'backend' folder
# ==============================================================================

# Backend Service Server Port & Host Configuration
PORT=8000
HOST=127.0.0.1

# Database Configuration
# Supported SQLite: sqlite:///./dataviz.db or PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./dataviz.db

# Authentication Security (Generate a secure key with: openssl rand -hex 32)
SECRET_KEY=YOUR_SECURE_JWT_SECRET_KEY_PLACEHOLDER
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
