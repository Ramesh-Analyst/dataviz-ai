# Environment Configurations for DataViz AI Backend
PORT=8000
HOST=127.0.0.1

# Database Configuration
# For local SQLite development, use: sqlite:///./dataviz.db
# For PostgreSQL development, use: postgresql://username:password@localhost:5432/dataviz_ai
DATABASE_URL=sqlite:///./dataviz.db

# Authentication Security
SECRET_KEY=your-secret-key-hereALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload Rules
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
